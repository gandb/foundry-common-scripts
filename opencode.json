{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-zen/big-pickle",
  "small_model": "opencode-zen/minimax-m2.5-free",
  "provider": {
    "opencode-zen": {
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "nemotron-3-super-free": {
          "name": "Nemotron 3 Super Free"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3:8b": {
          "name": "Qwen3 8B (local)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen2.5 Coder 7B (local)",
          "tools": true,
          "reasoning": true,
          "limit": { "context": 16384, "output": 4096 }
        },
        "falcon3:10b": {
          "name": "falcon3:10b  (local)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "gemma4:latest": {
          "name": "gemma4:latest (local)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 16384,
            "output": 4096
          }
        }
      }
    },
    "github-copilot": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 180000
      },
      "models": {
        "claude-opus-4": {
          "variants": {
            "medium": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 8000
              }
            },
            "high": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 16000
              }
            },
            "max": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 32000
              }
            }
          }
        }
      }
    }
  },

  "permission": {
    "bash": {
      "*": "ask",
      "git": "allow",
      "cat": "allow",
      "ls": "allow",
      "echo": "allow",
      "wc": "allow",
      "less": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow"
  },
  "agent": {
    "SCRUM_MASTER": {
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      }
    },
    "PRODUCT_OWNER": {
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      }
    },
    "DOCUMENTATION_WRITER": {
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      }
    },
    "ARCHITECT": {
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      }
    },
    "CODE_REVIEWER": {
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "TESTER": {
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    },
    "DEVELOPER": {
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "bkp/**"]
  },
  "skills": {
    "path": ".opencode/skills"
  },
  "instructions": ["./docs/CONSTITUTION.md"],
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [".ts", ".mjs", ".json"]
    }
  },
  "share": "manual",
  "autoupdate": "notify"
}
