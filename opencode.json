{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-zen/big-pickle",
  "small_model": "opencode-zen/minimax-m2.5-free",
  "provider": {
    "openrouter": {
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "nvidia/nemotron-nano-12b-v2-vl:free": {
          "name": "Nvidia Nemotron Nano 12B V2 VL Free"
        },
        "nvidia/nemotron-nano-9b-v2:free": {
          "name": "Nvidia Nemotron Nano 9B V2 Free"
        },
        "google/gemma-4-31b-it:free": {
          "name": "Google Gemma 4 31B IT Free"
        },
        "meta-llama/llama-3.3-70b-instruct:free": {
          "name": "Meta Llama 3.3 70B Instruct Free"
        },
        "qwen/qwen3-coder:free": {
          "name": "Qwen3 Coder Free"
        },
        "z-ai/glm-4.5-air:free": {
          "name": "Z-AI GLM 4.5 Air Free"
        },
        "openai/gpt-oss-120b:free": {
          "name": " OpenAI GPT OSS 120B Free"
        },
        "nvidia/nemotron-3-nano-30b-a3b:free": {
          "name": "Nvidia Nemotron 3 Nano 30B A3B Free"
        },
        "openrouter/elephant-alpha": {
          "name": "Elephant Alpha Free"
        },
        "moonshotai/kimi-k2.5": {
          "name": "Kimi K2.5 Free"
        },
        "meta-llama/Llama-3.1-8B-Instruct-Free": {
          "name": "Llama 3.1 8B Instruct Free"
        },
        "meta-llama/Llama-3.2-1B-Instruct-Free": {
          "name": "Llama 3.2 1B Instruct Free"
        },
        "mistralai/Mistral-Nemo-Base-2407": {
          "name": "Mistral Nemo Base 2407 Free"
        },
        "google/gemini-2.5-flash-lite": {
          "name": "Gemini 2.5 Flash Lite Free"
        }
      }
    },
    "opencode-zen": {
      "options": {
        "baseURL": "https://opencode.ai/zen/v1"
      },
      "models": {
        "nemotron-3-super-free": {
          "name": "Nemotron 3 Super Free"
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local) Quen2_5-Coder-7B",
      "options": {
        "baseURL": "http://localhost:1337/v1"
      },
      "models": {
        "Qwen2_5_1-Coder-7B-Instruct-Q4_K_M": {
          "contextWindow": 32768,
          "maxTokens": 4096,
          "reasoning": true,
          "tool_call": true
        },
        "qwen3:8b": {
          "name": "Qwen3 8B (local)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen2.5 Coder 7B (local)",
          "tools": true,
          "reasoning": true,
          "limit": { "context": 16384, "output": 4096 }
        },
        "falcon3:10b": {
          "name": "falcon3:10b  (local)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 16384,
            "output": 4096
          }
        },
        "gemma4:latest": {
          "name": "gemma4:latest (local)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 16384,
            "output": 4096
          }
        }
      }
    },
    "github-copilot": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 180000
      },
      "models": {
        "claude-opus-4": {
          "variants": {
            "medium": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 8000
              }
            },
            "high": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 16000
              }
            },
            "max": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 32000
              }
            }
          }
        }
      }
    }
  },

  "permission": {
    "bash": {
      "*": "ask",
      "git": "allow",
      "cat": "allow",
      "ls": "allow",
      "echo": "allow",
      "wc": "allow",
      "less": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow"
  },
  "agent": {
    "SCRUM_MASTER": {
      "type": "orchestrator",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      },
      "responsibilities": {
        "monitor_next_agent": true,
        "takeover_if_no_response": true,
        "continue_flow_after_takeover": true
      }
    },
    "PRODUCT_OWNER": {
      "type": "orchestrator",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      }
    },
    "DOCUMENTATION_WRITER": {
      "type": "subagent",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      }
    },
    "ARCHITECT": {
      "type": "subagent",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      }
    },
    "CODE_REVIEWER": {
      "type": "subagent",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "TESTER": {
      "type": "subagent",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    },
    "DEVELOPER": {
      "type": "subagent",
      "mode": "subagent",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "bkp/**"]
  },
  "skills": {
    "path": ".opencode/skills"
  },
  "instructions": ["./docs/CONSTITUTION.md"],
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [".ts", ".mjs", ".json"]
    }
  },
  "share": "manual",
  "autoupdate": "notify"
}
