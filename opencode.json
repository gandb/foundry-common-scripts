{
  "$schema": "https://opencode.ai/config.json",
    "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "bkp/**"
    ]
  },
  "skills": {
    "path": ".opencode/skills"
  },
  "instructions": [
    "./docs/AGENTS.md"
  ],
  "formatter": {
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".ts",
        ".mjs",
        ".json"
      ]
    }
  },

  "share": "manual",
  "autoupdate": "notify"
}
