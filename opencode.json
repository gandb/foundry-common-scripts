{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4",
  "small_model": "github-copilot/gpt-4o-mini",
  "provider": {
    "github-copilot": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "claude-opus-4": {
          "variants": {
            "medium": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 8000
              }
            },
            "high": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 16000
              }
            },
            "max": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 32000
              }
            }
          }
        }
      }
    }
  },
  "enabled_providers": ["github-copilot"],
  "permission": {
    "edit": "grant",
    "write": "grant",
    "read": "grant",
    "glob": "grant",
    "grep": "grant",
    "bash": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "bkp/**"]
  },
  "instructions": [".opencode/CONSTITUTION.md"],
  "formatter": {
    "prettier": {
      "command": ["npx", "prettier", "--write", "$FILE"],
      "extensions": [".ts", ".mjs", ".json"]
    }
  },
  "share": "manual",
  "autoupdate": "notify"
}
