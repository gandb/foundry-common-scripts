{
  "compilerOptions": {
    // Language/Target
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],

    // Modules: Modern ESM, not CommonJS
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "auto",

    // TypeScript Strict mode + "use strict" in generated JS
    "strict": true,
    "alwaysStrict": true,

    "typeRoots": ["types"],

    // Output
    "sourceMap": true,
    "outDir": "./dist",

    // Type Quality / Compatibility
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src", "dist/common/npc/npc.ts", "dist/common/npc/npcDialog.ts", "dist/common/npc/npcTalkDialog.ts", "dist/common/npc/button.ts"],
  "exclude": ["node_modules"]
}
